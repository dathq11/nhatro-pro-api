# Copy file này thành .env và điền thông tin của bạn

# Chuỗi kết nối PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/nhatro"

# Tài khoản đăng nhập app
AUTH_USERNAME="your-username"
AUTH_PASSWORD="your-password"

# Chuỗi bí mật để ký token (random string dài >= 32 ký tự)
AUTH_SECRET="your-random-secret-key"
