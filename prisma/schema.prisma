generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String     @id @default(cuid())
  email        String?    @unique
  phone        String?    @unique
  passwordHash String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  properties   Property[]
}

model Property {
  id              String   @id @default(cuid())
  userId          String
  name            String
  address         String
  floors          Int
  totalRooms      Int
  contractMonths  Int
  contractStart   DateTime
  baseRent        Int
  photos          String[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  rooms Room[]

  @@index([userId])
}

model Room {
  id         String     @id @default(cuid())
  propertyId String
  name       String
  rent       Int
  status     RoomStatus @default(VACANT)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  property     Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  contracts    Contract[]
  invoices     Invoice[]
  transactions Transaction[]

  @@index([propertyId])
  @@index([status])
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  cccd      String
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contracts Contract[]
}

model Contract {
  id         String           @id @default(cuid())
  roomId     String
  tenantId   String
  rent       Int
  months     Int
  signDate   DateTime
  endDate    DateTime
  status     ContractStatus   @default(ACTIVE)
  vehicles   Int              @default(0)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  room         Room          @relation(fields: [roomId], references: [id], onDelete: Cascade)
  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  invoices     Invoice[]
  transactions Transaction[]

  @@index([roomId, status])
  @@index([status])
}

model Invoice {
  id             String        @id @default(cuid())
  invoiceNumber  String        @unique
  month          String
  roomId         String
  contractId     String?
  tenantName     String
  rentAmount     Int
  electricKwh    Int           @default(0)
  electricPrice  Int           @default(4000)
  electricAmount Int           @default(0)
  waterM3        Int           @default(0)
  waterPrice     Int           @default(15000)
  waterAmount    Int           @default(0)
  internetAmount Int           @default(0)
  serviceAmount  Int           @default(0)
  otherFees      Json          @default("[]")
  totalAmount    Int
  note           String        @default("")
  status         InvoiceStatus @default(DRAFT)
  fileUrl        String?
  createdAt      DateTime      @default(now())
  issuedAt       DateTime?
  paidAt         DateTime?
  updatedAt      DateTime      @updatedAt

  room         Room          @relation(fields: [roomId], references: [id], onDelete: Cascade)
  contract     Contract?     @relation(fields: [contractId], references: [id])
  transactions Transaction[]

  @@index([roomId, month])
  @@index([month, status])
}

model Transaction {
  id         String              @id @default(cuid())
  type       TransactionType
  category   TransactionCategory
  amount     Int
  date       DateTime
  note       String              @default("")
  roomId     String?
  contractId String?
  invoiceId  String?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  room     Room?     @relation(fields: [roomId], references: [id])
  contract Contract? @relation(fields: [contractId], references: [id])
  invoice  Invoice?  @relation(fields: [invoiceId], references: [id])
}

enum RoomStatus {
  VACANT
  OCCUPIED
  UNPAID
  EXPIRING_SOON
}

enum ContractStatus {
  ACTIVE
  EXPIRED
  TERMINATED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum TransactionCategory {
  RENT
  DEPOSIT
  REPAIR
  UTILITIES
  OTHER
}
